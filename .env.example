## CosmoChat environment example
## Copy to .env and adjust values.

# PostgreSQL (used by JavaFX app)
POSTGRES_DB=cosmochat
POSTGRES_USER=cosmochat
POSTGRES_PASSWORD=cosmochat

# JavaFX app DB URL (must match the Postgres settings above)
COSMOCHAT_DB_URL=jdbc:postgresql://localhost:5433/cosmochat
COSMOCHAT_DB_USER=cosmochat
COSMOCHAT_DB_PASSWORD=cosmochat

# HuggingFace service (optional; used by docker-compose huggingface-service)
HF_TOKEN=your_hf_token_here
HF_API_BASE_URL=https://router.huggingface.co/v1
HF_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct
HF_NSCALE_SUFFIX=:featherless-ai
