# HuggingFace API Configuration
# Get your token from https://huggingface.co/settings/tokens

# Required: HuggingFace API token (read permission)
HF_TOKEN=your_hf_token_here

# Optional: Custom API base URL (default: https://router.huggingface.co/v1)
# HF_API_BASE_URL=https://router.huggingface.co/v1

# Optional: Model ID (default: Qwen/Qwen2.5-Coder-7B-Instruct)
# HF_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct

# Server port (default: 8080)
# SERVER_PORT=8080
