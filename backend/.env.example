# CosmoChat Python Backend Environment Variables

# Flask settings
FLASK_ENV=production
FLASK_DEBUG=0

# Model parameters (defaults can be overridden in API requests)
MAX_TOKENS=512
TEMPERATURE=0.7

# Number of threads for llama.cpp (adjust based on CPU cores)
LLAMA_THREADS=4
LLAMA_GPU_LAYERS=0  # Set >0 if you have CUDA-capable GPU

# Host binding (0.0.0.0 for external access)
HOST=0.0.0.0
